# Neon PostgreSQL
DATABASE_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require&pgbouncer=true&connect_timeout=10
DIRECT_URL=postgresql://user:pass@ep-xxx.region.aws.neon.tech:5432/dbname?sslmode=require

# Auth
JWT_ACCESS_SECRET=generate_with_openssl_rand_hex_32
JWT_REFRESH_SECRET=generate_with_openssl_rand_hex_32

# Custodial wallet encryption (must be exactly 64 hex chars = 32 bytes)
WALLET_MASTER_KEY=generate_with_node_crypto_randomBytes_32_hex
QR_MASTER_KEY=generate_with_node_crypto_randomBytes_32_hex

# Polygon blockchain
POLYGON_RPC_URL=https://rpc-amoy.polygon.technology
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY
NFT_CONTRACT_ADDRESS=0x...
MARKETPLACE_CONTRACT_ADDRESS=0x...
USDC_CONTRACT_ADDRESS=0x3c499c542cEF5E3811e1192ce70d8cC03d5c3359

# NFT metadata base URI
NFT_BASE_URI=https://YOUR_RAILWAY_URL/metadata/

# PayPal Braintree
BRAINTREE_ENV=sandbox
BRAINTREE_MERCHANT_ID=your_merchant_id
BRAINTREE_PUBLIC_KEY=your_public_key
BRAINTREE_PRIVATE_KEY=your_private_key

# Resend email
RESEND_API_KEY=re_xxxx
FROM_EMAIL=tickets@yourdomain.com

# Cloudflare R2
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret
R2_BUCKET_NAME=blockchain-tickets
R2_PUBLIC_URL=https://cdn.yourdomain.com

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# App
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:8081
